{
  "name": "Trufflehog",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Professional-grade credential sniffing and secret detection.",
  "homepage_url": "https://trufflesecurity.com",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trufflehog",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "notifications",
    "webRequest",
    "cookies"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
